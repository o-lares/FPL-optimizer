    "audit": "npm audit --audit-level=moderate",
    "deploy": "npm run build && wrangler deploy"
  },
  "dependencies": {
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@cloudflare/vite-plugin": "^1.40.2",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^5.0.0",
    "typescript": "^5.8.0",
    "vite": "^8.0.16",
    "vitest": "^4.1.8",
    "wrangler": "^4.100.0"
  }
}
