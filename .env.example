# Default is https://cors.eu.org/{url}
# Set to "direct" only if the FPL API allows browser CORS for your environment.
# For a Cloudflare Worker, use:
# VITE_FPL_PROXY_URL=https://YOUR_WORKER.YOUR_SUBDOMAIN.workers.dev/?url={encodedUrl}
# You can provide comma-separated fallbacks. Use {url} for the raw target URL
# or {encodedUrl} for a URL-encoded target URL.
VITE_FPL_PROXY_URL=https://cors.eu.org/{url}
